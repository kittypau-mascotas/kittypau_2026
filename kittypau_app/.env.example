# Public values (these can be present in browser/APK)
NEXT_PUBLIC_SITE_URL="https://kittypau-app.vercel.app"
NEXT_PUBLIC_APP_FLAVOR="web"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
CAPACITOR_SERVER_URL="https://app.kittypau-app.vercel.app"

# MQTT WebSocket — read-only, seguro para el browser
# Crear usuario read-only en HiveMQ Dashboard con ACL: +/SENSORS (subscribe only)
NEXT_PUBLIC_MQTT_BROKER="YOUR_HIVEMQ_HOST.hivemq.cloud"
NEXT_PUBLIC_MQTT_PORT_WS="8884"
NEXT_PUBLIC_MQTT_USER_READONLY="replace_me"
NEXT_PUBLIC_MQTT_PASS_READONLY="replace_me"

# Server-only values (never put these in mobile client code)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"
MQTT_WEBHOOK_SECRET="replace_me"
BRIDGE_HEARTBEAT_SECRET="replace_me"
CRON_SECRET="replace_me"
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace_me"
VERCEL_API_TOKEN="replace_me"

# Analytics DB — optional/legacy server-only (leave empty if you do not use the
# historical analytics database)
SUPABASE_ANALYTICS_URL="https://YOUR_ANALYTICS_PROJECT.supabase.co"
SUPABASE_ANALYTICS_SERVICE_KEY="sb_secret_analytics_xxx"
