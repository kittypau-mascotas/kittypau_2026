## Bridge v2.4 env (example)
## Copiar como .env en la RPi: /home/kittypau/kittypau-bridge/.env

# HiveMQ / MQTT
MQTT_BROKER=<TU_HOST_HIVEMQ>
MQTT_PORT=8883
MQTT_USER=<TU_USUARIO_HIVEMQ>
MQTT_PASS=<TU_PASSWORD_HIVEMQ>

# Supabase (directo — service role bypasa RLS)
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<TU_SERVICE_ROLE_KEY>
